# CryptPad environment configuration

# Timezone
TZ=America/New_York

# Hostname / domain
BASE_HOST_NAME=$HOSTNAME
BASE_DOMAIN_NAME=example.com

# CryptPad domains
# Main domain (where users access CryptPad)
# CPAD_MAIN_DOMAIN=cryptpad.example.com
# Sandbox domain (must be a different subdomain for security)
CRYPTPAD_SANDBOX_DOMAIN=sandbox.localhost

# Restrict registration (true/false)
CRYPTPAD_RESTRICT_REGISTRATION=false
